LOG_LEVEL=INFO
PORT=8003

DATABASE_URL=postgresql://mcp:mcp@localhost:5432/mcp
DB_SCHEMA=mcp_router

REDIS_URL=redis://localhost:6379/3
REDIS_KEY_PREFIX=mcp
CACHE_TTL_SECONDS=300

# ── Auth ─────────────────────────────────────────────────────────────
# `none` (dev-only unless AUTH_ALLOW_NONE_IN_PROD=true), `jwt`,
# `api_key`, or `both`.
AUTH_MODE=none

# Used when AUTH_MODE includes `jwt`. Router-owned secret — not shared
# with any caller's identity system.
JWT_SECRET=
JWT_ALGORITHM=HS256

# Used when AUTH_MODE includes `api_key`. Comma-separated. Rotate by
# adding the new key first, rolling callers, then removing the old one.
API_KEYS_ADMIN=
API_KEYS_READER=

# Boot-time refusal escape hatch — only relevant when AUTH_MODE=none in
# a non-dev deployment (e.g. router lives behind an authenticating
# edge). Router logs a WARNING on every request in this mode.
AUTH_ALLOW_NONE_IN_PROD=false

# ── MCP-server call timeouts
DISCOVERY_TIMEOUT_MS=10000
RESOLUTION_CALL_TIMEOUT_MS=30000

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
